PUID=950
PGID=950
TZ=Europe/London

# Custom WireGuard (ProtonVPN example). Get these from your provider.
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=<your-wireguard-private-key>
WIREGUARD_PUBLIC_KEY=<peer-public-key>
WIREGUARD_ADDRESSES=10.2.0.2/32
WIREGUARD_ENDPOINT_IP=<vpn-server-ip>
WIREGUARD_ENDPOINT_PORT=51820
VPN_ENDPOINT_IP=<vpn-server-ip>
VPN_ENDPOINT_PORT=51820

# Allow LAN access so you can still reach the WebUI
FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24
DNS_ADDRESS=10.2.0.1
