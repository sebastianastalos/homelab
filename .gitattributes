# Normalize line endings across platforms
* text=auto eol=lf

# Explicit text files
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.conf     text eol=lf
*.env      text eol=lf
*.example  text eol=lf
*.sh       text eol=lf

# Binary — do not diff / normalize
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.db       binary
*.sqlite   binary
