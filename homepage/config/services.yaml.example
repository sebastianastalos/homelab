- Tools:
    - Code Server:
        icon: vscode.png
        href: http://192.168.1.131:8443
        description: VS Code Editor
        siteMonitor: http://192.168.1.131:8443
    - Homepage:
        icon: homepage.png
        href: http://192.168.1.131:3000
        description: Dashboard
        siteMonitor: http://192.168.1.131:3000
    - Tailscale:
        icon: tailscale.png
        href: https://login.tailscale.com/admin/machines
        description: Remote Access
