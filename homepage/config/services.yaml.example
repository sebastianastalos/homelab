    - Radarr:
        icon: radarr.png
        href: http://192.168.1.131:7878
        description: Movies
        siteMonitor: http://192.168.1.131:7878
        widget:
          type: radarr
          url: http://192.168.1.131:7878
          key: <radarr-api-key>
    - Prowlarr:
        icon: prowlarr.png
        href: http://192.168.1.131:9696
