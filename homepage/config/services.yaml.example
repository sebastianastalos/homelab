- Media:
    - Jellyfin:
        icon: jellyfin.png
        href: http://192.168.1.131:8096
        description: Media Server
        siteMonitor: http://192.168.1.131:8096
        widget:
          type: jellyfin
          url: http://192.168.1.131:8096
          key: <jellyfin-api-key>
          enableBlocks: true
    - Seerr:
        icon: overseerr.png
        href: http://192.168.1.131:5055
        description: Media Requests
        siteMonitor: http://192.168.1.131:5055
        widget:
          type: seerr
          url: http://192.168.1.131:5055
          key: <seerr-api-key>

- Downloads:
    - qBittorrent:
        icon: qbittorrent.png
        href: http://192.168.1.131:8082
        description: Torrent Client
        siteMonitor: http://192.168.1.131:8082
        widget:
          type: qbittorrent
          url: http://192.168.1.131:8082
          username: <webui-username>
          password: <webui-password>
    - SABnzbd:
        icon: sabnzbd.png
        href: http://192.168.1.131:8085
        description: Usenet Client
        siteMonitor: http://192.168.1.131:8085
        widget:
          type: sabnzbd
          url: http://192.168.1.131:8085
          key: <sabnzbd-api-key>
    - GlueTUN:
        icon: gluetun.png
        href: http://192.168.1.131:8000
        description: VPN Container
        siteMonitor: http://192.168.1.131:8888
        widget:
          type: gluetun
          url: http://192.168.1.131:8000

- Management:
    - Sonarr:
        icon: sonarr.png
        href: http://192.168.1.131:8989
        description: TV & Anime
        siteMonitor: http://192.168.1.131:8989
